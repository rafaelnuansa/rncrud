{
    "name": "rafaelnuansa/rncrud",
    "description": "A powerful Artisan command to generate flexible Laravel CRUD scaffolding",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "rafaelnuansa\\MapCrud\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "rafaelnuansa\\MapCrud\\RNCrudServiceProvider"
            ]
        }
    },
    "require": {
        "php": ">=8.1 <8.6",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/console": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/filesystem": "^10.0|^11.0|^12.0|^13.0",
        "laravel/prompts": "^0.3.16"
    }
}
